#!/usr/bin/env bash

# Help menu
if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    echo "Usage: serve [PORT] [DIRECTORY]"
    echo "Starts a lightweight Python HTTP server."
    echo ""
    echo "  PORT       Port to bind to (default: 8000)"
    echo "  DIRECTORY  Directory to serve (default: .)"
    exit 0
fi

set -euo pipefail

PORT="${1:-8000}"
DIR="${2:-.}"

# Cross-platform local IP grabber.
# Linux: parse `ip route get` (no DNS lookup, instant).
# macOS: ask the routing table via `route get`, fall back to ipconfig.
if [[ "$OSTYPE" == darwin* ]]; then
    IFACE=$(route -n get 1.1.1.1 2>/dev/null | awk '/interface:/ {print $2}')
    IP=$(ipconfig getifaddr "${IFACE:-en0}" 2>/dev/null || echo "127.0.0.1")
else
    IP=$(ip route get 1.1.1.1 2>/dev/null | awk '/src/ {for (i=1;i<=NF;i++) if ($i=="src") print $(i+1)}')
    IP="${IP:-127.0.0.1}"
fi

# Display the complete URL
echo -e "Serving \033[1;33m$DIR\033[0m at \033[1;36mhttp://$IP:$PORT\033[0m"

# Execute the server
python3 -m http.server "$PORT" -d "$DIR"
