#!/usr/bin/env bash
set -euo pipefail

# Bootstrap the Neovim toolchain on Ubuntu.
#
# Mason installs most LSPs/formatters/linters at runtime, but it relies on a
# working set of language toolchains being available system-wide. When those
# are missing, half the Mason packages silently fail to install. This script
# pre-stages every external dependency the nvim config needs, so the very
# first `nvim` launch can pull everything down cleanly.
#
# What gets installed:
#
#   * Neovim itself, from the official GitHub release tarball into ~/.local.
#     Ubuntu 24.04 ships nvim 0.9.5 in apt — too old for `vim.lsp.config`
#     and nvim-treesitter `main`. We avoid `add-apt-repository ppa:neovim-
#     ppa/...` because it talks to api.launchpad.net via Python's
#     launchpadlib, which routinely times out on OCI shapes and aborts the
#     whole bootstrap with a TimeoutError. GitHub Releases is reachable
#     anywhere this dotfiles repo can be cloned from.
#   * Build toolchain     — gcc, make, git, unzip (treesitter parsers,
#                            telescope-fzf-native, blink.cmp regex engine).
#   * Node.js + npm        — pyright, bashls, html, cssls, prettier.
#   * Python + pip + pipx  — fallback path for Mason recipes / ruff backups.
#   * default-jre-headless — google-java-format runs as a JAR.
#   * tree-sitter CLI      — required by nvim-treesitter `main` to compile
#                            parsers (not packaged in apt; installed via npm
#                            into ~/.local to avoid sudo).
#   * ripgrep, fd-find     — telescope live_grep / find_files.
#
# Idempotent: re-run any time you suspect Mason is missing a toolchain. Safe
# to run on its own or as a final step inside `./forge`. Network-fragile
# steps (GitHub fetch, headless plugin sync) warn-and-continue rather than
# aborting, so a partial failure still leaves the system better off.

if ! command -v apt-get >/dev/null 2>&1; then
    echo "apt-get not found — this script targets Ubuntu/Debian. Aborting." >&2
    exit 1
fi

# Ensure ~/.local/bin (where we land nvim and tree-sitter) wins in PATH for
# the rest of this script's lifetime, regardless of how the user's shell rc
# orders things.
export PATH="$HOME/.local/bin:$PATH"

# --- Neovim binary ----------------------------------------------------------
NVIM_MIN_MAJOR=0
NVIM_MIN_MINOR=11

nvim_is_recent_enough() {
    command -v nvim >/dev/null 2>&1 || return 1
    local ver major minor
    ver=$(nvim --version 2>/dev/null | head -1 | grep -oE '[0-9]+\.[0-9]+' | head -1) || return 1
    major=${ver%%.*}
    minor=${ver#*.}
    if (( major > NVIM_MIN_MAJOR )); then
        return 0
    fi
    if (( major == NVIM_MIN_MAJOR && minor >= NVIM_MIN_MINOR )); then
        return 0
    fi
    return 1
}

install_neovim_from_github() {
    local arch asset url tmp extracted
    arch=$(uname -m)
    case "$arch" in
        x86_64)  asset='nvim-linux-x86_64.tar.gz' ;;
        aarch64) asset='nvim-linux-arm64.tar.gz' ;;
        *) echo "  Unsupported arch: $arch" >&2; return 1 ;;
    esac
    url="https://github.com/neovim/neovim/releases/latest/download/$asset"
    tmp=$(mktemp -d) || return 1
    echo "  Downloading $asset..."
    if ! curl -fsSL --connect-timeout 15 --retry 2 -o "$tmp/$asset" "$url"; then
        rm -rf "$tmp"
        return 1
    fi
    if ! tar -xzf "$tmp/$asset" -C "$tmp"; then
        rm -rf "$tmp"
        return 1
    fi
    extracted=$(find "$tmp" -maxdepth 1 -type d -name 'nvim-linux-*' | head -1)
    if [[ -z $extracted ]]; then
        echo "  Extracted tarball had no nvim-linux-* directory." >&2
        rm -rf "$tmp"
        return 1
    fi
    mkdir -p "$HOME/.local/share" "$HOME/.local/bin"
    rm -rf "$HOME/.local/share/nvim-prebuilt"
    mv "$extracted" "$HOME/.local/share/nvim-prebuilt"
    ln -sf "$HOME/.local/share/nvim-prebuilt/bin/nvim" "$HOME/.local/bin/nvim"
    rm -rf "$tmp"
}

if nvim_is_recent_enough; then
    echo "nvim already at $(nvim --version | head -1) — skipping reinstall."
else
    echo "Installing latest nvim from GitHub release into ~/.local..."
    if install_neovim_from_github; then
        echo "  Installed: $(nvim --version | head -1)"
    else
        echo "  GitHub fetch failed — keeping whatever nvim is already on PATH." >&2
        echo "  The Lazy/Mason sync below needs nvim >= 0.${NVIM_MIN_MINOR}." >&2
        echo "  Re-run forge-nvim once the network is reachable." >&2
    fi
fi

# --- Toolchain packages -----------------------------------------------------
APT_PACKAGES=(
    # Build toolchain (treesitter parsers, fzf-native, blink.cmp)
    'build-essential'
    'gcc'
    'make'
    'git'
    'curl'
    'unzip'
    'ca-certificates'
    # Node — drives Mason installs of the npm-based LSPs and prettier
    'nodejs'
    'npm'
    # Python — Mason fallback path; ruff's secondary install route
    'python3'
    'python3-pip'
    'python3-venv'
    'pipx'
    # JRE — google-java-format ships as a runnable JAR
    'default-jre-headless'
    # Telescope live_grep / find_files
    'ripgrep'
    'fd-find'
)

echo
echo "Updating apt index..."
sudo apt-get update

echo "Installing nvim toolchain dependencies..."
sudo apt-get install -y --no-install-recommends "${APT_PACKAGES[@]}" || {
    echo "Bulk install failed; retrying individually so the rest still install..."
    for pkg in "${APT_PACKAGES[@]}"; do
        sudo apt-get install -y --no-install-recommends "$pkg" || echo "  skipped: $pkg"
    done
}

# --- bin shims --------------------------------------------------------------
# Ubuntu names fd's binary `fdfind`; nvim/telescope etc. call `fd`. The same
# applies to `nodejs` vs `node` on some Ubuntu releases — many npm-installed
# Mason packages call `node` directly.
mkdir -p "$HOME/.local/bin"
if [[ -x /usr/bin/fdfind && ! -e "$HOME/.local/bin/fd" ]]; then
    ln -s /usr/bin/fdfind "$HOME/.local/bin/fd"
fi
if [[ -x /usr/bin/nodejs && ! -e "$HOME/.local/bin/node" ]] && ! command -v node >/dev/null 2>&1; then
    ln -s /usr/bin/nodejs "$HOME/.local/bin/node"
fi

# --- tree-sitter CLI --------------------------------------------------------
# nvim-treesitter `main` compiles parsers via the `tree-sitter` CLI. Not in
# apt — install via npm into a user prefix so we don't need sudo for global
# npm modules.
if ! command -v tree-sitter >/dev/null 2>&1; then
    if command -v npm >/dev/null 2>&1; then
        echo "Installing tree-sitter CLI via npm..."
        mkdir -p "$HOME/.local"
        npm config set prefix "$HOME/.local"
        if ! npm install -g tree-sitter-cli; then
            echo "  tree-sitter-cli install failed — re-run later or build via cargo." >&2
        fi
    else
        echo "  npm not available; skipping tree-sitter CLI install." >&2
    fi
fi

# --- Headless first-run -----------------------------------------------------
# Trigger Lazy plugin sync so the next interactive launch is instant. Mason's
# `ensure_installed` will run automatically as nvim-lspconfig loads inside
# the headless session. Treesitter parsers are compiled by the plugin's
# `build = ':TSUpdate'` hook during Lazy sync.
#
# Best-effort: if either step exits non-zero we just print a hint — the user
# can always finish the install interactively with `:Lazy sync` / `:Mason`.
if nvim_is_recent_enough; then
    echo
    echo "Running headless Lazy sync — this compiles treesitter parsers and"
    echo "kicks off Mason installs. First run can take a couple of minutes."
    if ! nvim --headless "+Lazy! sync" +qa; then
        echo "  Lazy sync exited non-zero. Open nvim and run :Lazy to inspect."
    fi
    echo
    echo "Running MasonToolsInstallSync (blocking install of every tool)..."
    if ! nvim --headless "+MasonToolsInstallSync" +qa; then
        echo "  Mason install exited non-zero. Open nvim and run :Mason."
    fi
else
    echo
    echo "Skipping headless sync — no nvim 0.${NVIM_MIN_MINOR}+ on PATH."
fi

# --- Status summary ---------------------------------------------------------
status() {
    local name=$1 cmd=$2
    if command -v "$cmd" >/dev/null 2>&1; then
        printf "  %-18s %s\n" "$name" "$(command -v "$cmd")"
    else
        printf "  %-18s MISSING\n" "$name"
    fi
}

echo
echo "Toolchain status:"
status "nvim" nvim
status "node" node
status "npm" npm
status "python3" python3
status "pip3" pip3
status "pipx" pipx
status "java" java
status "gcc" gcc
status "make" make
status "git" git
status "tree-sitter" tree-sitter
status "rg" rg
status "fd" fd

echo
echo "Neovim bootstrap complete."
echo "Open nvim and run \`:checkhealth\` to verify everything resolved."
