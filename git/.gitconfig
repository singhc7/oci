[user]
	name = Chahatpreet Singh
	email = c@chahat.dev
	signingkey = ~/.ssh/id_ed25519.pub
[gpg]
	format = ssh
[commit]
	gpgsign = true
[tag]
	gpgsign = true
	sort = -version:refname
[init]
	defaultBranch = main
[fetch]
	prune = true
[push]
	autoSetupRemote = true
	default = simple
[pull]
	rebase = true
[rebase]
	autosquash = true
	autostash = true
[rerere]
	enabled = true
[column]
	ui = auto
[branch]
	sort = -committerdate
[diff]
	algorithm = histogram
	colorMoved = default
	mnemonicPrefix = true
	renames = copies
[merge]
	conflictstyle = zdiff3
[core]
	editor = nvim
[alias]
	st = status -sb
	co = checkout
	cob = checkout -b
	br = branch
	ci = commit
	amend = commit --amend --no-edit
	undo = reset --soft HEAD~1
	unstage = restore --staged
	last = log -1 HEAD --stat
	pushf = push --force-with-lease
	lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
