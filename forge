#!/usr/bin/env bash
set -euo pipefail

# Bootstrap a headless Ubuntu OCI instance from this dotfiles repo.
#
# Assumes the repo is already cloned to ~/dotfiles and that `git` and
# `stow` are available (the `bootstrap` block below installs them if not).
#
# Tested on Ubuntu 24.04 LTS (OCI Always Free aarch64/amd64 shapes).
# Should also work on 22.04, but a few packages (btop, eza, tealdeer)
# will be missing from the default repos there.

if ! command -v apt-get >/dev/null 2>&1; then
    echo "apt-get not found — this script targets Ubuntu/Debian. Aborting." >&2
    exit 1
fi

# --- Packages ---------------------------------------------------------------
# Headless server set: shells, tooling, editor, and a few CLI utilities.
# GUI/Wayland apps live in the Arch dotfiles repo, not here.
APT_PACKAGES=(
    # Core tooling
    'git'
    'stow'
    'curl'
    'ca-certificates'
    'build-essential'
    'unzip'
    # Shells & multiplexer
    'zsh'
    'tmux'
    # Editor & language tooling
    'neovim'
    'python3-pip'
    'python3-venv'
    'pipx'
    # CLI productivity
    'aria2'
    'bat'           # binary is `batcat` on Ubuntu — symlinked below
    'btop'          # 24.04+; 22.04 ships an older version, install will still succeed
    'eza'           # 24.04+; on 22.04 `apt install` will fail — see fallback below
    'fd-find'       # binary is `fdfind` on Ubuntu — symlinked below
    'fzf'
    'jq'
    'nnn'
    'ripgrep'
    'tealdeer'      # 24.04+; on 22.04 falls back to cargo if available
    'yt-dlp'
    'zoxide'
    # Backup / sync
    'borgbackup'
    'rclone'
)

PACKAGESTOSTOW=(
    'aria2'
    'bash'
    'btop'
    'eza'
    'fzf'
    'git'
    'neovim'
    'nnn'
    'scripts'
    'tealdeer'
    'tmux'
    'yt-dlp'
    'zsh'
)

# --- Install ----------------------------------------------------------------
echo "Updating apt index and upgrading existing packages..."
sudo apt-get update
sudo apt-get -y full-upgrade

echo "Installing packages..."
# `--no-install-recommends` keeps the install lean (no GUI bait).
# `|| true` on the bulk install lets us continue if a single package is
# missing on this Ubuntu release; we'll catch the gaps via fallbacks.
sudo apt-get install -y --no-install-recommends "${APT_PACKAGES[@]}" || {
    echo "One or more apt packages failed; retrying individually so the rest still install..."
    for pkg in "${APT_PACKAGES[@]}"; do
        sudo apt-get install -y --no-install-recommends "$pkg" || echo "  skipped: $pkg"
    done
}

# `bat` and `fd` ship under different binary names on Ubuntu to avoid
# clashing with existing tools. Add user-local symlinks so configs that
# reference `bat`/`fd` (e.g. fzf preview) work without forking.
mkdir -p "$HOME/.local/bin"
if [[ -x /usr/bin/batcat && ! -e "$HOME/.local/bin/bat" ]]; then
    ln -s /usr/bin/batcat "$HOME/.local/bin/bat"
fi
if [[ -x /usr/bin/fdfind && ! -e "$HOME/.local/bin/fd" ]]; then
    ln -s /usr/bin/fdfind "$HOME/.local/bin/fd"
fi

# --- Symlink dotfiles -------------------------------------------------------
echo "Linking dotfiles via GNU stow..."
cd "$HOME/dotfiles" || {
    echo "~/dotfiles not found. Clone the repo there first." >&2
    exit 1
}
stow -R "${PACKAGESTOSTOW[@]}"

# --- Antidote (zsh plugin manager) ------------------------------------------
if [[ ! -d "$HOME/.antidote" ]]; then
    echo "Installing Antidote..."
    git clone --depth=1 https://github.com/mattmc3/antidote.git "$HOME/.antidote"
fi

# --- Default shell ----------------------------------------------------------
# Make zsh the login shell if it isn't already. Skipped silently if zsh
# isn't on the system (e.g. apt couldn't fetch it).
if command -v zsh >/dev/null 2>&1 && [[ "$SHELL" != *zsh ]]; then
    echo "Setting zsh as the default login shell..."
    sudo chsh -s "$(command -v zsh)" "$USER"
fi

echo
echo "Bootstrap complete."
echo "Log out and back in so the new shell + symlinks pick up cleanly."
