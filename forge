#!/usr/bin/env bash
set -euo pipefail

# Bootstrap a headless Ubuntu OCI instance from this dotfiles repo.
#
# Assumes the repo is already cloned to ~/dotfiles and that `git` and
# `stow` are available (the `bootstrap` block below installs them if not).
#
# apt is reserved strictly for system binaries (build chain, login shell,
# system Python, Homebrew prerequisites). Every userland CLI tool ships
# from Homebrew so we get fresh releases regardless of Ubuntu version.
#
# Tested on Ubuntu 24.04 LTS (OCI Always Free aarch64/amd64 shapes).

if ! command -v apt-get >/dev/null 2>&1; then
    echo "apt-get not found — this script targets Ubuntu/Debian. Aborting." >&2
    exit 1
fi

# --- Packages ---------------------------------------------------------------
# Split into two groups:
#   * apt — strictly system binaries: bootstrap toolchain, login shells, the
#     system Python stack, and Homebrew's own prerequisites.
#   * brew — every other userland CLI tool. Homebrew gives us fresher releases
#     than Ubuntu's archive (24.04 has stale btop/eza/tealdeer, 22.04 is even
#     further behind) and a single source of truth for non-system tooling.
APT_PACKAGES=(
    # Bootstrap toolchain
    'git'
    'stow'
    'curl'
    'ca-certificates'
    'build-essential'
    'unzip'
    # Homebrew install prerequisites (in addition to the bootstrap set above)
    'procps'
    'file'
    # Login shell
    'zsh'
    # System Python stack
    'python3-pip'
    'python3-venv'
    'pipx'
)

BREW_PACKAGES=(
    # Multiplexer & editor
    'tmux'
    'neovim'
    # CLI productivity
    'aria2'
    'bat'
    'btop'
    'eza'
    'fd'
    'fzf'
    'jq'
    'nnn'
    'ripgrep'
    'tealdeer'
    'yt-dlp'
    'zoxide'
    # Backup / sync
    'borgbackup'
    'rclone'
)

PACKAGESTOSTOW=(
    'aria2'
    'bash'
    'btop'
    'eza'
    'fzf'
    'git'
    'neovim'
    'nnn'
    'scripts'
    'tealdeer'
    'tmux'
    'yt-dlp'
    'zsh'
)

# --- Install ----------------------------------------------------------------
echo "Updating apt index and upgrading existing packages..."
sudo apt-get update
sudo apt-get -y full-upgrade

echo "Installing packages..."
# `--no-install-recommends` keeps the install lean (no GUI bait).
# `|| true` on the bulk install lets us continue if a single package is
# missing on this Ubuntu release; we'll catch the gaps via fallbacks.
sudo apt-get install -y --no-install-recommends "${APT_PACKAGES[@]}" || {
    echo "One or more apt packages failed; retrying individually so the rest still install..."
    for pkg in "${APT_PACKAGES[@]}"; do
        sudo apt-get install -y --no-install-recommends "$pkg" || echo "  skipped: $pkg"
    done
}

mkdir -p "$HOME/.local/bin"

# --- Homebrew ---------------------------------------------------------------
# Userland tools come from brew (see comment on BREW_PACKAGES above). Install
# is idempotent — we skip if `brew` is already on PATH or the linuxbrew prefix
# already exists.
if ! command -v brew >/dev/null 2>&1 && [[ ! -x /home/linuxbrew/.linuxbrew/bin/brew ]]; then
    echo "Installing Homebrew..."
    NONINTERACTIVE=1 /bin/bash -c \
        "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

# Make brew available in this script's process so the install loop below
# works on the very first `forge` run, before the shell rcs are stowed.
if [[ -x /home/linuxbrew/.linuxbrew/bin/brew ]]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

if command -v brew >/dev/null 2>&1; then
    echo "Installing brew packages..."
    brew install "${BREW_PACKAGES[@]}" || {
        echo "One or more brew packages failed; retrying individually..."
        for pkg in "${BREW_PACKAGES[@]}"; do
            brew install "$pkg" || echo "  skipped: $pkg"
        done
    }
else
    echo "brew not on PATH after install attempt — skipping brew packages." >&2
    echo "Re-run forge once Homebrew is reachable." >&2
fi

# --- Symlink dotfiles -------------------------------------------------------
echo "Linking dotfiles via GNU stow..."
cd "$HOME/dotfiles" || {
    echo "~/dotfiles not found. Clone the repo there first." >&2
    exit 1
}
stow -R "${PACKAGESTOSTOW[@]}"

# --- Neovim toolchain -------------------------------------------------------
# Delegated to ./forge-nvim so it can be re-run on its own when Mason is
# missing tools. The script is idempotent — safe to invoke unconditionally.
if [[ -x "$HOME/dotfiles/forge-nvim" ]]; then
    echo "Bootstrapping nvim toolchain via ./forge-nvim..."
    "$HOME/dotfiles/forge-nvim"
fi

# --- Antidote (zsh plugin manager) ------------------------------------------
if [[ ! -d "$HOME/.antidote" ]]; then
    echo "Installing Antidote..."
    git clone --depth=1 https://github.com/mattmc3/antidote.git "$HOME/.antidote"
fi

# --- Default shell ----------------------------------------------------------
# Make zsh the login shell if it isn't already. Skipped silently if zsh
# isn't on the system (e.g. apt couldn't fetch it).
if command -v zsh >/dev/null 2>&1 && [[ "$SHELL" != *zsh ]]; then
    echo "Setting zsh as the default login shell..."
    sudo chsh -s "$(command -v zsh)" "$USER"
fi

echo
echo "Bootstrap complete."
echo "Log out and back in so the new shell + symlinks pick up cleanly."
